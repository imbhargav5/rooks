{
  "extends": "@repo/typescript-config/react-library.json",
  "include": ["src"],
  "exclude": ["dist", "build", "node_modules", "src/__tests__"],
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["es2022", "DOM", "DOM.Iterable", "ESNext.Disposable"],
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
