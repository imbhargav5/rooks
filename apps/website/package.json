  },
  "devDependencies": {
    "@content-collections/cli": "^0.1.9",
    "@content-collections/core": "^0.14.2",
    "@content-collections/next": "^0.2.11",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "concurrently": "^9.2.1",
